{
  "chat.commandCenter.enabled": false,
  "editor.fontFamily": "JetBrainsMono Nerd Font",
  "editor.fontLigatures": true,
  "editor.fontSize": 13,
  "editor.lineHeight": 1.2,
  "editor.minimap.enabled": false,
  "editor.mouseWheelZoom": true,
  "explorer.autoReveal": true,
  "files.autoSave": "afterDelay",
  "http.proxyStrictSSL": false,
  "git.openRepositoryInParentFolders": "always",
  "numberedBookmarks.navigateThroughAllFiles": "replace",
  "telemetry.telemetryLevel": "off",
  "vim.hlsearch": true,
  "vim.incsearch": true,
  "vim.showcmd": true,
  "vim.smartRelativeLine": true,
  "vim.sneak": true,
  "vim.surround": true,
  "vim.useCtrlKeys": true,
  "vim.useSystemClipboard": true,
  "window.commandCenter": false,
  "window.menuBarVisibility": "toggle",
  "workbench.activityBar.iconClickBehavior": "toggle",
  "workbench.activityBar.location": "top",
  "workbench.colorTheme": "GitHub Dark Default",
  "workbench.iconTheme": "material-icon-theme",
  "workbench.tree.renderIndentGuides": "onHover",
  "vim.insertModeKeyBindings": [
    {
      "before": ["j", "j"],
      "after": ["<Esc>"]
    }
  ],
  "vim.normalModeKeyBindingsNonRecursive": [
    {
      "before": ["]", "m"],
      "commands": ["gotoNextPreviousMember.nextMember"]
    },
    {
      "before": ["[", "m"],
      "commands": ["gotoNextPreviousMember.previousMember"]
    },
    {
      "before": ["]", "e"],
      "commands": ["editor.action.marker.next"]
    },
    {
      "before": ["[", "e"],
      "commands": ["editor.action.marker.prev"]
    },
    {
      "before": ["]", "d"],
      "commands": ["editor.action.accessibleDiffViewer.next"]
    },
    {
      "before": ["[", "d"],
      "commands": ["editor.action.accessibleDiffViewer.prev"]
    },
    {
      "before": ["]", "c"],
      "commands": ["workbench.action.editor.nextChange"]
    },
    {
      "before": ["[", "c"],
      "commands": ["workbench.action.editor.previousChange"]
    },
    {
      "before": ["'", "0"],
      "commands": ["numberedBookmarks.jumpToBookmark0"]
    },
    {
      "before": ["'", "1"],
      "commands": ["numberedBookmarks.jumpToBookmark1"]
    },
    {
      "before": ["'", "2"],
      "commands": ["numberedBookmarks.jumpToBookmark2"]
    },
    {
      "before": ["'", "3"],
      "commands": ["numberedBookmarks.jumpToBookmark3"]
    },
    {
      "before": ["'", "4"],
      "commands": ["numberedBookmarks.jumpToBookmark4"]
    },
    {
      "before": ["'", "5"],
      "commands": ["numberedBookmarks.jumpToBookmark5"]
    },
    {
      "before": ["'", "6"],
      "commands": ["numberedBookmarks.jumpToBookmark6"]
    },
    {
      "before": ["'", "7"],
      "commands": ["numberedBookmarks.jumpToBookmark7"]
    },
    {
      "before": ["'", "8"],
      "commands": ["numberedBookmarks.jumpToBookmark8"]
    },
    {
      "before": ["'", "9"],
      "commands": ["numberedBookmarks.jumpToBookmark9"]
    },
    {
      "before": ["+"],
      "after": ["<c-w>", ">"]
    },
    {
      "before": ["-"],
      "after": ["<c-w>", "-"]
    },
    {
      "before": ["<Tab>"],
      "after": ["g", "t"]
    },
    {
      "before": ["<c-d>"],
      "after": ["<c-d>", "z", "z"]
    },
    {
      "before": ["<c-u>"],
      "after": ["<c-u>", "z", "z"]
    },
    {
      "before": ["g", "i"],
      "commands": ["editor.action.goToImplementation"]
    },
    {
      "before": ["g", "s"],
      "commands": ["java.action.navigateToSuperImplementation"]
    },
    {
      "before": ["g", "t"],
      "commands": ["java.test.goToTest"]
    },
    {
      "before": ["g", "T"],
      "commands": ["java.test.goToTestSubject"]
    },
    {
      "before": ["<s-Tab>"],
      "after": ["g", "T"]
    },
    {
      "before": ["="],
      "after": ["<c-w>", "+"]
    },
    {
      "before": ["H"],
      "after": ["^"]
    },
    {
      "before": ["J"],
      "after": ["}"]
    },
    {
      "before": ["K"],
      "after": ["{"]
    },
    {
      "before": ["L"],
      "after": ["$"]
    },
    {
      "before": ["N"],
      "after": ["N", "z", "z", "z", "v"]
    },
    {
      "before": ["["],
      "commands": ["editor.action.marker.prev"]
    },
    {
      "before": ["]"],
      "commands": ["editor.action.marker.next"]
    },
    {
      "before": ["{"],
      "command": ["workbench.action.editor.previousChange"]
    },
    {
      "before": ["}"],
      "commands": ["workbench.action.editor.nextChange"]
    },
    {
      "before": ["("],
      "commands": ["workbench.action.compareEditor.previousChange"]
    },
    {
      "before": [")"],
      "commands": ["workbench.action.compareEditor.nextChange"]
    },
    {
      "before": ["_"],
      "after": ["<c-w>", "<"]
    },
    {
      "before": ["g", "i"],
      "commands": ["editor.action.goToImplementation"]
    },
    {
      "before": ["m", "0"],
      "commands": ["numberedBookmarks.toggleBookmark0"]
    },
    {
      "before": ["m", "1"],
      "commands": ["numberedBookmarks.toggleBookmark1"]
    },
    {
      "before": ["m", "2"],
      "commands": ["numberedBookmarks.toggleBookmark2"]
    },
    {
      "before": ["m", "3"],
      "commands": ["numberedBookmarks.toggleBookmark3"]
    },
    {
      "before": ["m", "4"],
      "commands": ["numberedBookmarks.toggleBookmark4"]
    },
    {
      "before": ["m", "5"],
      "commands": ["numberedBookmarks.toggleBookmark5"]
    },
    {
      "before": ["m", "6"],
      "commands": ["numberedBookmarks.toggleBookmark6"]
    },
    {
      "before": ["m", "7"],
      "commands": ["numberedBookmarks.toggleBookmark7"]
    },
    {
      "before": ["m", "8"],
      "commands": ["numberedBookmarks.toggleBookmark8"]
    },
    {
      "before": ["m", "9"],
      "commands": ["numberedBookmarks.toggleBookmark9"]
    },
    {
      "before": ["n"],
      "after": ["n", "z", "z", "z", "v"]
    }
  ],
  "vim.visualModeKeyBindingsNonRecursive": [
    {
      "before": ["H"],
      "after": ["^"]
    },
    {
      "before": ["L"],
      "after": ["$"]
    },
    {
      "before": ["J"],
      "after": ["}"]
    },
    {
      "before": ["K"],
      "after": ["{"]
    },
    {
      "before": ["`"],
      "after": ["S", "`"]
    },
    {
      "before": ["'"],
      "after": ["S", "'"]
    },
    {
      "before": ["\""],
      "after": ["S", "\""]
    },
    {
      "before": ["("],
      "after": ["S", "("]
    },
    {
      "before": [")"],
      "after": ["S", ")"]
    },
    {
      "before": ["["],
      "after": ["S", "["]
    },
    {
      "before": ["]"],
      "after": ["S", "]"]
    },
    {
      "before": ["{"],
      "after": ["S", "{"]
    },
    {
      "before": ["}"],
      "after": ["S", "}"]
    },
    {
      "before": ["<leader>", "e", "c"],
      "commands": [
        {
          "command": "editor.action.codeAction",
          "args": {
            "kind": "refactor.extract.constant"
          }
        }
      ]
    },
    {
      "before": ["<leader>", "e", "f"],
      "commands": [
        {
          "command": "editor.action.codeAction",
          "args": {
            "kind": "refactor.extract.field"
          }
        }
      ]
    },
    {
      "before": ["<leader>", "e", "m"],
      "commands": [
        {
          "command": "editor.action.codeAction",
          "args": {
            "kind": "refactor.extract.function"
          }
        }
      ]
    },
    {
      "before": ["<leader>", "e", "p"],
      "commands": [
        {
          "command": "editor.action.codeAction",
          "args": {
            "kind": "refactor.introduce"
          }
        }
      ]
    },
    {
      "before": ["<leader>", "e", "v"],
      "commands": [
        {
          "command": "editor.action.codeAction",
          "args": {
            "kind": "refactor.extract.variable"
          }
        }
      ]
    }
  ],
  "vim.leader": "<space>",
  "vim.handleKeys": {
    "<C-a>": false,
    "<C-b>": false,
    "<C-c>": true,
    "<C-e>": false,
    "<C-r>": true,
    "<C-v>": true,
    "<C-w>": false,
    "<C-x>": false
  },
  "extensions.experimental.affinity": {
    "vscodevim.vim": 1
  },
  "[jsonc]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  }
}
