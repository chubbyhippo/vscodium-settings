{
  "[jsonc]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "chat.commandCenter.enabled": false,
  "editor.fontFamily": "JetBrainsMono Nerd Font",
  "editor.fontLigatures": true,
  "editor.fontSize": 13,
  "editor.lineHeight": 1.2,
  "editor.mouseWheelZoom": true,
  "explorer.autoReveal": true,
  "extensions.experimental.affinity": {
    "vscodevim.vim": 1
  },
  "files.autoSave": "afterDelay",
  "git.openRepositoryInParentFolders": "always",
  "http.proxyStrictSSL": false,
  "numberedBookmarks.navigateThroughAllFiles": "replace",
  "telemetry.telemetryLevel": "off",
  "vim.handleKeys": {
    "<C-a>": false,
    "<C-b>": false,
    "<C-c>": true,
    "<C-e>": false,
    "<C-r>": true,
    "<C-v>": true,
    "<C-w>": false,
    "<C-x>": false
  },
  "vim.hlsearch": true,
  "vim.incsearch": true,
  "vim.insertModeKeyBindings": [
    {
      "after": ["<Esc>"],
      "before": ["j", "j"]
    }
  ],
  "vim.leader": "<space>",
  "vim.normalModeKeyBindingsNonRecursive": [
    {
      "before": ["]", "m"],
      "commands": ["gotoNextPreviousMember.nextMember"]
    },
    {
      "before": ["[", "m"],
      "commands": ["gotoNextPreviousMember.previousMember"]
    },
    {
      "before": ["]", "e"],
      "commands": ["editor.action.marker.next"]
    },
    {
      "before": ["[", "e"],
      "commands": ["editor.action.marker.prev"]
    },
    {
      "before": ["]", "d"],
      "commands": ["editor.action.accessibleDiffViewer.next"]
    },
    {
      "before": ["[", "d"],
      "commands": ["editor.action.accessibleDiffViewer.prev"]
    },
    {
      "before": ["]", "c"],
      "commands": ["workbench.action.editor.nextChange"]
    },
    {
      "before": ["[", "c"],
      "commands": ["workbench.action.editor.previousChange"]
    },
    {
      "before": ["'", "0"],
      "commands": ["numberedBookmarks.jumpToBookmark0"]
    },
    {
      "before": ["'", "1"],
      "commands": ["numberedBookmarks.jumpToBookmark1"]
    },
    {
      "before": ["'", "2"],
      "commands": ["numberedBookmarks.jumpToBookmark2"]
    },
    {
      "before": ["'", "3"],
      "commands": ["numberedBookmarks.jumpToBookmark3"]
    },
    {
      "before": ["'", "4"],
      "commands": ["numberedBookmarks.jumpToBookmark4"]
    },
    {
      "before": ["'", "5"],
      "commands": ["numberedBookmarks.jumpToBookmark5"]
    },
    {
      "before": ["'", "6"],
      "commands": ["numberedBookmarks.jumpToBookmark6"]
    },
    {
      "before": ["'", "7"],
      "commands": ["numberedBookmarks.jumpToBookmark7"]
    },
    {
      "before": ["'", "8"],
      "commands": ["numberedBookmarks.jumpToBookmark8"]
    },
    {
      "before": ["'", "9"],
      "commands": ["numberedBookmarks.jumpToBookmark9"]
    },
    {
      "after": ["<c-w>", ">"],
      "before": ["+"]
    },
    {
      "after": ["-", "<c-w>"],
      "before": ["-"]
    },
    {
      "after": ["g", "t"],
      "before": ["<Tab>"]
    },
    {
      "after": ["<c-d>", "z", "z"],
      "before": ["<c-d>"]
    },
    {
      "after": ["<c-u>", "z", "z"],
      "before": ["<c-u>"]
    },
    {
      "before": ["g", "i"],
      "commands": ["editor.action.goToImplementation"]
    },
    {
      "before": ["g", "s"],
      "commands": ["java.action.navigateToSuperImplementation"]
    },
    {
      "before": ["g", "t"],
      "commands": ["java.test.goToTest"]
    },
    {
      "before": ["g", "T"],
      "commands": ["java.test.goToTestSubject"]
    },
    {
      "after": ["g", "T"],
      "before": ["<s-Tab>"]
    },
    {
      "after": ["+", "<c-w>"],
      "before": ["="]
    },
    {
      "after": ["N", "v", "z", "z", "z"],
      "before": ["N"]
    },
    {
      "before": ["{"],
      "command": ["workbench.action.editor.previousChange"]
    },
    {
      "before": ["}"],
      "commands": ["workbench.action.editor.nextChange"]
    },
    {
      "before": ["("],
      "commands": ["workbench.action.compareEditor.previousChange"]
    },
    {
      "before": [")"],
      "commands": ["workbench.action.compareEditor.nextChange"]
    },
    {
      "after": ["<", "<c-w>"],
      "before": ["_"]
    },
    {
      "before": ["g", "i"],
      "commands": ["editor.action.goToImplementation"]
    },
    {
      "before": ["0", "m"],
      "commands": ["numberedBookmarks.toggleBookmark0"]
    },
    {
      "before": ["1", "m"],
      "commands": ["numberedBookmarks.toggleBookmark1"]
    },
    {
      "before": ["2", "m"],
      "commands": ["numberedBookmarks.toggleBookmark2"]
    },
    {
      "before": ["3", "m"],
      "commands": ["numberedBookmarks.toggleBookmark3"]
    },
    {
      "before": ["4", "m"],
      "commands": ["numberedBookmarks.toggleBookmark4"]
    },
    {
      "before": ["5", "m"],
      "commands": ["numberedBookmarks.toggleBookmark5"]
    },
    {
      "before": ["6", "m"],
      "commands": ["numberedBookmarks.toggleBookmark6"]
    },
    {
      "before": ["7", "m"],
      "commands": ["numberedBookmarks.toggleBookmark7"]
    },
    {
      "before": ["8", "m"],
      "commands": ["numberedBookmarks.toggleBookmark8"]
    },
    {
      "before": ["9", "m"],
      "commands": ["numberedBookmarks.toggleBookmark9"]
    },
    {
      "after": ["n", "v", "z", "z", "z"],
      "before": ["n"]
    }
  ],
  "vim.showcmd": true,
  "vim.smartRelativeLine": true,
  "vim.sneak": true,
  "vim.surround": true,
  "vim.useCtrlKeys": true,
  "vim.useSystemClipboard": true,
  "vim.visualModeKeyBindingsNonRecursive": [
    {
      "before": ["}"],
      "after": ["}", "S"]
    },
    {
      "before": ["{"],
      "after": ["{", "S"]
    },
    {
      "before": ["]"],
      "after": ["S", "]"]
    },
    {
      "before": ["["],
      "after": ["S", "["]
    },
    {
      "before": [")"],
      "after": ["S", ")"]
    },
    {
      "before": ["("],
      "after": ["S", "("]
    },
    {
      "before": ["\""],
      "after": ["S", "\""]
    },
    {
      "before": ["'"],
      "after": ["S", "'"]
    },
    {
      "before": ["`"],
      "after": ["S", "`"]
    }
  ],
  "window.commandCenter": false,
  "window.menuBarVisibility": "toggle",
  "workbench.activityBar.iconClickBehavior": "toggle",
  "workbench.activityBar.location": "top",
  "workbench.colorTheme": "GitHub Dark Default",
  "workbench.iconTheme": "material-icon-theme",
  "workbench.tree.renderIndentGuides": "onHover"
}
